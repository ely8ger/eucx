generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum UserRole {
  SUPER_ADMIN           // Vollzugriff auf Backoffice + alle Systeme
  COMPLIANCE_OFFICER    // KYC-Prüfung, Dispute-Entscheidung, Audit-Log-Einsicht
  ADMIN                 // Allgemeine Admin-Rechte (Produkte, Nutzer verwalten)
  WAREHOUSE_INSPECTOR   // Nur: Zertifikate hochladen, Mengen bestätigen
  SELLER
  BUYER
  BROKER
  OBSERVER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
  REJECTED   // Registrierung vom Admin abgelehnt
}

// KYC-Verifizierungsstatus — separater Lebenszyklus von UserStatus
enum VerificationStatus {
  GUEST                 // Registriert, keine Dokumente
  PENDING_VERIFICATION  // Dokumente eingereicht, wartet auf Prüfung
  VERIFIED              // Identität bestätigt, darf handeln
  REJECTED              // Dokumente abgelehnt (z.B. unvollständig)
  SUSPENDED             // Konto gesperrt (Compliance-Entscheidung)
}

enum DisputeStatus {
  OPEN        // Streitfall eröffnet, Trade eingefroren
  UNDER_REVIEW // Compliance-Mitarbeiter prüft
  RESOLVED    // Streit beigelegt, Trade fortgesetzt
  CANCELLED   // Trade storniert, Storno-Buchung ausgelöst
}

enum DisputeResolution {
  TRADE_UPHELD    // Trade wie abgeschlossen, Käufer unterliegt
  TRADE_REVERSED  // Storno — alle Ledger-Einträge werden gegengebucht
  PARTIAL_REFUND  // Teilrückerstattung (manuell definierter Betrag)
}

enum CommodityUnit {
  TON       // Tonne (Metalle, Agrar, Schrott)
  KG        // Kilogramm
  CBM       // Kubikmeter (Holz)
  LITER     // Liter (Chemie, Öl)
  PIECE     // Stück (Maschinen)
  SQM       // Quadratmeter (Bleche, Platten)
  MWH       // Megawattstunden (Energie)
}

enum OrderDirection {
  BUY
  SELL
}

// LIMIT: Preis wird vom Händler festgelegt — wird nur ausgeführt wenn Marktpreis passt
// MARKET: Sofort zum besten verfügbaren Preis ausführen
enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  ACTIVE
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
}

enum SessionStatus {
  SCHEDULED
  PRE_TRADING
  TRADING_1
  CORRECTION_1
  TRADING_2
  CORRECTION_2
  FINAL
  CLOSED
}

enum DealStatus {
  MATCHED
  CONFIRMED
  CONTRACT_SIGNED
  SETTLEMENT_COMPLETE  // Clearing abgeschlossen, Rechnungen erstellt
  CANCELLED
  DISPUTED
}

// ─── Reverse Auction (BUTB — Buyer-Takes-Best) ────────────────────────────────
// 4-Phasen-State-Machine:
//   COLLECTION → Käufer erstellt Lot, Verkäufer registrieren sich
//   PROPOSAL   → 2h-Fenster startet, Verkäufer geben Erstgebote ab
//   REDUCTION  → PriceEngine aktiv, jedes Gebot muss unter aktuellem Best liegen
//   CONCLUSION → Fenster geschlossen, Sieger fixiert, Datensatz eingefroren
enum AuctionPhase {
  COLLECTION
  PROPOSAL
  REDUCTION
  CONCLUSION
}

enum KycDocStatus {
  PENDING    // Eingereicht, wartet auf Admin-Prüfung
  APPROVED   // Akzeptiert
  REJECTED   // Abgelehnt (mit Begründung)
}

enum ContractStatus {
  PENDING_SIGNATURE  // PDF generiert, wartet auf EDS
  SIGNED             // Digital signiert, rechtsgültig
  EXPIRED            // Token abgelaufen, neu signieren erforderlich
}

// ─── Asset (physische Ware / Charge) ─────────────────────────────────────────
//
// State Machine:
//   INCOMING → PENDING_VERIFICATION (Dokument hochgeladen)
//            → VERIFIED             (alle Pflichtdokumente APPROVED)
//            → AVAILABLE            (Verkäufer listet Ware)
//            → RESERVED             (aktives Gebot läuft)
//            → SOLD                 (Deal abgeschlossen)
//            → IN_TRANSIT           (Logistik bestätigt)
//            → DELIVERED            (Abgeliefert)
//   * → QUARANTINE                  (Admin-Sperre)
enum AssetStatus {
  INCOMING             // Anlieferung registriert, noch keine Dokumente
  PENDING_VERIFICATION // Dokumente hochgeladen, warten auf Prüfung
  VERIFIED             // Alle Pflichtdokumente APPROVED — handelbar
  AVAILABLE            // Im Orderbuch gelistet
  RESERVED             // Aktives Gebot — kein weiteres Angebot möglich
  SOLD                 // Deal abgeschlossen
  IN_TRANSIT           // Transport zum Käufer läuft
  DELIVERED            // Abgeliefert, Prozess abgeschlossen
  QUARANTINE           // Gesperrt durch Admin (Qualitätsproblem o.ä.)
}

// Dokument-Typen (Pflicht je nach Kategorie — siehe REQUIRED_DOCS_PER_CATEGORY)
enum DocumentType {
  CERTIFICATE_OF_ANALYSIS   // CoA — Pflicht für Metalle, Chemie, Agrar
  CERTIFICATE_OF_ORIGIN     // Herkunftsnachweis — Pflicht für Agrar, Holz
  WEIGHT_CERTIFICATE        // Wiegeschein — Pflicht für Metalle, Schrott
  LME_WARRANT               // LME-Lagerwarrant — Pflicht wenn lmeRegistered=true
  PHYTOSANITARY             // Pflanzenschutzzertifikat — Agrar (EU-Import)
  CUSTOMS_DECLARATION       // Zollanmeldung — Pflicht für Chemie, Drittlandware
  TRANSPORT_DOCUMENT        // CMR / Frachtbrief — bei IN_TRANSIT
  QUALITY_INSPECTION        // Prüfbericht — Pflicht für Energie, Holz
  OTHER
}

enum DocumentStatus {
  PENDING   // Hochgeladen, noch nicht geprüft
  APPROVED  // Geprüft und akzeptiert
  REJECTED  // Abgelehnt (abgelaufen, falsch, unleserlich)
}

enum Currency {
  EUR
  PLN
  USD
  GBP
  CZK
  CHF
}

// ═══════════════════════════════════════════════════════════════════════════════
// KATEGORIEN (eigene Tabelle, nicht nur Enum — erweiterbar ohne Migration)
// ═══════════════════════════════════════════════════════════════════════════════

model Category {
  id          String  @id @default(uuid())
  slug        String  @unique  // z.B. "METALS", "AGRICULTURE"
  label       String           // Anzeigename: "Metalle & Legierungen"
  description String?
  icon        String?          // Emoji oder Icon-Key
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  // Pflichtfelder-Spezifikation (JSONB): welche Attribute muss ein Produkt dieser Kategorie haben
  // z.B. METALS: ["grade", "standard", "diameterMm"]
  // z.B. AGRICULTURE: ["harvestYear", "moistureContent"]
  requiredAttributes Json?

  products Product[]

  @@map("categories")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORGANISATIONEN & NUTZER
// ═══════════════════════════════════════════════════════════════════════════════

model Organization {
  id         String    @id @default(uuid())
  name       String
  taxId      String    @unique
  lei        String?   @unique
  country    String    @db.Char(2)
  city       String
  street     String?
  postalCode String?
  phone      String?
  hrb        String?
  legalForm  String?
  foundedAt  DateTime?
  naceCode   String?
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())

  users         User[]
  products      Product[]
  orders        Order[]
  dealsAsSeller Deal[]    @relation("SellerOrg")
  dealsAsBuyer  Deal[]    @relation("BuyerOrg")
  assets        Asset[]
  wallet        Wallet?
  apiKeys       ApiKey[]
  webhooks      WebhookEndpoint[]

  @@map("organizations")
}

model User {
  id                  String             @id @default(uuid())
  organizationId      String
  email               String             @unique
  passwordHash        String
  role                UserRole           @default(BUYER)
  status              UserStatus         @default(PENDING)
  verificationStatus  VerificationStatus @default(GUEST)
  isYoungCompany      Boolean            @default(false)   // < 2 Jahre alt → 5%-Depot-Pflicht
  companyFoundedAt    DateTime?                            // Gründungsdatum (aus Handelsregister)
  totpSecret          String?
  totpEnabled         Boolean            @default(false)
  emailVerified       Boolean            @default(false)   // E-Mail-Adresse bestätigt
  phoneVerified       Boolean            @default(false)   // Telefonnummer verifiziert
  failedLoginCount    Int                @default(0)       // Fehlversuche seit letztem Erfolg
  lockedUntil         DateTime?                            // Account gesperrt bis (null = nicht gesperrt)
  rejectionReason     String?                              // Grund der Ablehnung durch Admin
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id])
  orders         Order[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  adminNotes     AdminNote[]      @relation("SubjectNotes")     // Notizen über diesen User
  writtenNotes   AdminNote[]      @relation("AuthorNotes")      // Notizen von diesem Admin
  disputesRaised TradeDispute[]   @relation("DisputeRaiser")    // Streitfälle eröffnet
  disputesReviewed TradeDispute[] @relation("DisputeReviewer")  // Als Admin bearbeitet
  lotsAsBuyer           Lot[]            @relation("LotBuyer")
  lotsAsWinner          Lot[]            @relation("LotWinner")
  bids                  Bid[]
  lotRegistrations      LotRegistration[]
  kycDocuments          KycDocument[]
  lotContractsAsBuyer     LotContract[]            @relation("LotContractBuyer")
  lotContractsAsSeller    LotContract[]            @relation("LotContractSeller")
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  emailVerifications      EmailVerification[]
  passwordResetTokens     PasswordResetToken[]

  @@index([organizationId])
  @@index([verificationStatus])   // KYC-Queue: alle PENDING_VERIFICATION schnell abrufen
  @@index([status])               // Registrierungs-Queue
  @@map("users")
}

// ─── AdminNote — interne Notizen zu Usern ────────────────────────────────────
// Unveränderbar: Notizen werden NIE gelöscht (Compliance-Anforderung).
// Zeitstempel + Author-ID machen den Audit-Trail vollständig.

model AdminNote {
  id        String   @id @default(uuid())
  subjectId String   // User, über den die Notiz geschrieben wird
  authorId  String   // Admin/Compliance-Mitarbeiter, der schreibt
  content   String   // Freitext (z.B. "Gewerbeanmeldung unleserlich")
  isFlag    Boolean  @default(false)  // true = kritische Markierung (rot anzeigen)
  createdAt DateTime @default(now())

  subject User @relation("SubjectNotes", fields: [subjectId], references: [id])
  author  User @relation("AuthorNotes",  fields: [authorId],  references: [id])

  @@index([subjectId])
  @@map("admin_notes")
}

// ─── EmailVerification — Bestätigungscode bei Registrierung ──────────────────
// 6-stelliger numerischer Code, gültig 15 Minuten.
// Nach Bestätigung: emailVerified=true, Token gelöscht.

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  email     String
  code      String   // 6-stelliger Hash-Code
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@map("email_verifications")
}

// ─── PasswordResetToken — Token für Passwort-Zurücksetzen ─────────────────────
// SHA-256-gehashter Token, gültig 1 Stunde.
// Wird erstellt wenn: (a) Nutzer fordert Reset an, (b) Account nach 5 Fehlversuchen gesperrt.

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique  // SHA-256 des gesendeten Tokens
  expiresAt  DateTime
  usedAt     DateTime?
  reason     String    @default("USER_REQUEST")  // "USER_REQUEST" | "BRUTE_FORCE_LOCK"
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── TradeDispute — Streitfall-Ticket ────────────────────────────────────────
// Wird erstellt wenn Käufer oder Verkäufer einen Trade anfechten.
// Deal.status → DISPUTED (Trade eingefroren, kein Settlement möglich)
//
// Auflösung durch COMPLIANCE_OFFICER oder SUPER_ADMIN:
//   RESOLVED     → Deal weiter wie geplant
//   CANCELLED    → cancelTrade() im ClearingService (Storno-Buchungen)
//   PARTIAL_REFUND → manualRefundAmount wird vom Admin festgelegt

model TradeDispute {
  id               String             @id @default(uuid())
  dealId           String             @unique  // 1 Dispute pro Deal
  raisedById       String
  reviewedById     String?

  status           DisputeStatus      @default(OPEN)
  resolution       DisputeResolution?

  // Streitgrund
  reason           String             // Freitext: "Metallqualität weicht von CoA ab"
  evidenceUrls     String[]           // Links zu hochgeladenen Beweisdokumenten

  // Admin-Entscheidung
  adminComment     String?
  manualRefundAmount Decimal?         @db.Decimal(18, 8)  // Nur bei PARTIAL_REFUND

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  resolvedAt       DateTime?

  deal       Deal  @relation(fields: [dealId],       references: [id])
  raisedBy   User  @relation("DisputeRaiser",  fields: [raisedById],   references: [id])
  reviewedBy User? @relation("DisputeReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([raisedById])
  @@map("trade_disputes")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUKTE — Multi-Commodity mit JSONB-Attributen
//
// Architektur-Entscheidung: JSONB statt EAV-Tabelle
// Grund: PostgreSQL JSONB ist GIN-indexierbar, hat native Operatoren (@>, ?)
//        und ist 10x schneller als 3-Table-Join beim EAV-Pattern.
//        EAV eignet sich nur wenn Attribute selbst gehandelt werden (z.B. Config-Store).
// ═══════════════════════════════════════════════════════════════════════════════

model Product {
  id                String        @id @default(uuid())
  organizationId    String
  categoryId        String

  // Allgemeine Felder (für alle Kategorien)
  sku               String        @unique   // Stock Keeping Unit — eindeutige Produktnummer
  name              String
  description       String?
  unit              CommodityUnit @default(TON)
  quantity          Decimal       @db.Decimal(18, 8)  // präzise für Millionen-Mengen
  minLotQuantity    Decimal       @default(1.0) @db.Decimal(18, 8)
  originCountry     String        @db.Char(2)
  warehouseLocation String
  hasCertificate    Boolean       @default(false)
  certificateNumber String?
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Kategorie-spezifische Attribute (JSONB — GIN-indexiert)
  // Metalle:      { grade, standard, diameterMm, lengthMm, yieldStrengthMpa, ... }
  // Agrar:        { harvestYear, moistureContent, proteinContent, originFarm, ... }
  // Energie:      { calorificValueMj, ashContentPct, sulfurPct, ... }
  // Holz:         { woodSpecies, dryingMethod, moisturePct, ... }
  attributes       Json?

  organization    Organization     @relation(fields: [organizationId], references: [id])
  category        Category         @relation(fields: [categoryId], references: [id])
  tradingSessions TradingSession[]
  orders          Order[]
  deals           Deal[]
  assets          Asset[]
  marketCandles   MarketCandle[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([isActive])
  // GIN-Index für JSONB-Attribut-Suche (z.B. alle Produkte mit grade="BSt500S")
  @@index([attributes], type: Gin)
  @@map("products")
}

// ═══════════════════════════════════════════════════════════════════════════════
// HANDELSSITZUNGEN & ORDERBUCH
// ═══════════════════════════════════════════════════════════════════════════════

model TradingSession {
  id             String        @id @default(uuid())
  productId      String
  currentStatus  SessionStatus @default(SCHEDULED)
  scheduledStart DateTime
  endedAt        DateTime?
  createdAt      DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id])
  orders  Order[]
  deals   Deal[]

  @@index([productId])
  @@index([currentStatus])
  @@index([scheduledStart])
  @@map("trading_sessions")
}

model Order {
  id             String         @id @default(uuid())
  sessionId      String
  userId         String
  organizationId String
  productId      String
  direction      OrderDirection
  orderType      OrderType      @default(LIMIT)   // NEU: LIMIT oder MARKET

  // Preise: Decimal(18,8) — 8 Nachkommastellen für Krypto-ähnliche Präzision
  // Beispiel: 1.234.567,12345678 EUR/t — kein Rundungsfehler bei Millionen-Deals
  pricePerUnit   Decimal        @db.Decimal(18, 8)
  currency       Currency       @default(EUR)
  quantity       Decimal        @db.Decimal(18, 8)
  filledQuantity Decimal        @default(0) @db.Decimal(18, 8)
  status         OrderStatus    @default(ACTIVE)
  idempotencyKey String         @unique     // Double-Spend-Schutz Layer 1
  expiresAt      DateTime?                  // für LIMIT Orders mit Ablaufzeit
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  session      TradingSession @relation(fields: [sessionId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  organization Organization   @relation(fields: [organizationId], references: [id])
  product      Product        @relation(fields: [productId], references: [id])
  dealsAsSell  Deal[]         @relation("SellOrder")
  dealsAsBuy   Deal[]         @relation("BuyOrder")

  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([direction, pricePerUnit])   // Orderbuch-Sortierung
  @@index([expiresAt])                 // Expired-Order Cleanup
  @@map("orders")
}

// Abgeschlossenes Geschäft (Trade) — entspricht einem "Matches" in der BUTB
model Deal {
  id           String     @id @default(uuid())
  sessionId    String
  sellOrderId  String
  buyOrderId   String
  sellerOrgId  String
  buyerOrgId   String
  productId    String
  quantity     Decimal    @db.Decimal(18, 8)
  pricePerUnit Decimal    @db.Decimal(18, 8)
  totalValue   Decimal    @db.Decimal(24, 8)  // pricePerUnit × quantity — extra Stellen
  currency     Currency   @default(EUR)
  status       DealStatus @default(MATCHED)
  createdAt    DateTime   @default(now())

  session    TradingSession @relation(fields: [sessionId], references: [id])
  sellOrder  Order          @relation("SellOrder", fields: [sellOrderId], references: [id])
  buyOrder   Order          @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellerOrg  Organization   @relation("SellerOrg", fields: [sellerOrgId], references: [id])
  buyerOrg   Organization   @relation("BuyerOrg", fields: [buyerOrgId], references: [id])
  product    Product        @relation(fields: [productId], references: [id])
  contract   Contract?
  settlement Settlement?
  invoices   Invoice[]
  dispute    TradeDispute?

  @@index([sessionId])
  @@index([sellerOrgId])
  @@index([buyerOrgId])
  @@index([createdAt])
  @@map("deals")
}

// ═══════════════════════════════════════════════════════════════════════════════
// VERTRÄGE — Automatisch generierte PDFs mit SHA-256-Fingerprint
//
// Ablauf:
//   1. Deal MATCHED → POST /api/contracts erstellt PDF + Hash
//   2. System zeigt 6-stelligen EDS-Token (Mock-QES)
//   3. User bestätigt Token → Deal STATUS → CONTRACT_SIGNED
//   4. pdfHash in AuditLog (unveränderlich) — Fälschungssicherheit
//
// Sicherheit:
//   pdfHash = SHA-256(pdfBytes) — gespeichert VOR Signatur
//   Nachträgliche PDF-Änderung → Hash-Mismatch → sofort erkennbar
// ═══════════════════════════════════════════════════════════════════════════════

model Contract {
  id           String         @id @default(uuid())
  dealId       String         @unique
  pdfBase64    String         // Generated PDF, base64-encoded (stored once at signing time)
  pdfHash      String         // SHA-256 hex — Integritätsbeweis (immutable nach Erstellung)
  pdfSizeBytes Int
  status       ContractStatus @default(PENDING_SIGNATURE)
  edsTokenHash String?        // bcrypt-Hash des Mock-EDS-Tokens
  edsTokenExp  DateTime?      // Token-Ablaufzeit (5 Minuten)
  signedAt     DateTime?      // Zeitpunkt der Signatur
  signerUserId String?        // Wer hat signiert
  createdAt    DateTime       @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([status])
  @@map("contracts")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════════════════════════════════

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIT LOG — Event Sourcing, immutable
//
// Regel: NIEMALS löschen oder updaten. Nur INSERT erlaubt.
// Revisionssicherheit: jeder Klick, jede Order, jede Preisänderung wird gespeichert.
// ═══════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // "AUTH_LOGIN" | "ORDER_SUBMITTED" | "PRODUCT_CREATED" | ...
  entityType String   // "Order" | "Product" | "User" | "Deal"
  entityId   String?
  ipAddress  String?
  userAgent  String?
  meta       Json?    // Freie Metadaten (JSONB) — z.B. alter/neuer Wert bei Updates
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

// ═══════════════════════════════════════════════════════════════════════════════
// LAGER & ASSET-VERWALTUNG — Digitaler Zwilling physischer Chargen
//
// Konzept:
//   Product = Produktdefinition (Typ, Spezifikation)
//   Asset   = Konkrete Charge im Lager (20t Kupfer, BatchID EUCX-2026-CU-0042)
//
// Ein Produkt kann mehrere Assets haben (verschiedene Chargen).
// Jede Charge hat eigenen Status, eigene Dokumente, eigenes Lager.
// ═══════════════════════════════════════════════════════════════════════════════

model Warehouse {
  id           String   @id @default(uuid())
  code         String   @unique  // z.B. "DE-HH-01" (Land-Stadt-Nummer)
  name         String
  address      String
  city         String
  country      String   @db.Char(2)
  postalCode   String?
  isActive     Boolean  @default(true)
  // Koordinaten für Logistik-Optimierung
  latitude     Float?
  longitude    Float?
  // Lagerkapazität gesamt (t / CBM je nach Typ)
  capacityTotal  Decimal? @db.Decimal(18, 3)
  capacityUsed   Decimal? @db.Decimal(18, 3)
  createdAt    DateTime @default(now())

  assets Asset[]

  @@index([country])
  @@map("warehouses")
}

model Asset {
  id                String        @id @default(uuid())
  batchId           String        @unique  // z.B. "EUCX-2026-CU-0042" — menschenlesbar

  // Verknüpfungen
  productId         String
  organizationId    String        // Eigentümer (Verkäufer)
  warehouseId       String

  // Mengen
  quantityTotal     Decimal       @db.Decimal(18, 8)  // ursprüngliche Einlieferungsmenge
  quantityAvailable Decimal       @db.Decimal(18, 8)  // nach Teilverkäufen

  unit              CommodityUnit @default(TON)

  // ── State Machine ──────────────────────────────────────────────────────────
  status            AssetStatus   @default(INCOMING)

  // ── Physikalische Details ──────────────────────────────────────────────────
  grossWeightKg     Decimal?      @db.Decimal(18, 3)  // Bruttogewicht
  netWeightKg       Decimal?      @db.Decimal(18, 3)  // Nettogewicht
  packagingType     String?       // "pallets" | "coils" | "drums" | "bulk" | "containers"
  palletCount       Int?

  // ── Verifizierte Kategorie-Attribute (erst nach VERIFIED befüllt) ──────────
  // Metalle:  { purityPct: 99.95, lmeRegistered: true, lmeWarrantNumber: "LME-...", grade: "CU-CATH" }
  // Agrar:    { moistureContentPct: 14.2, proteinContentPct: 12.1, harvestYear: 2025 }
  // Energie:  { deliveryStart: "2026-04-01", deliveryEnd: "2026-04-30", feedInPoint: "DE-HH-01", powerMw: 50 }
  verifiedAttributes Json?

  // ── Logistik ───────────────────────────────────────────────────────────────
  arrivalDate       DateTime?     // Eingang im Lager
  expiryDate        DateTime?     // Ablaufdatum (z.B. Agrar-Ware)

  // ── Verifikation ───────────────────────────────────────────────────────────
  verifiedAt        DateTime?
  verifiedByUserId  String?

  // ── Reservation ────────────────────────────────────────────────────────────
  // Gesetzt wenn status=RESERVED — welche Order hält die Reservierung
  reservedByOrderId String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  product      Product      @relation(fields: [productId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  documents    AssetDocument[]

  @@index([productId])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([status])
  @@index([batchId])
  @@map("assets")
}

model AssetDocument {
  id               String         @id @default(uuid())
  assetId          String
  documentType     DocumentType
  status           DocumentStatus @default(PENDING)

  // Datei-Metadaten (kein direktes File-Storage — nur Hash + Referenz)
  fileName         String
  fileHash         String         // SHA-256 — Manipulationsschutz
  fileSizeBytes    Int
  mimeType         String         // "application/pdf" | "image/jpeg" | ...
  storageUrl       String?        // Vercel Blob / S3 URL (optional für Phase 2)

  // Zertifikats-Details
  issuedBy         String?        // Ausstellende Organisation / Labor
  issuedAt         DateTime?      // Ausstellungsdatum
  expiresAt        DateTime?      // Ablaufdatum — REJECTED wenn abgelaufen

  // Prüfung durch EUCX-Mitarbeiter (Admin-Workflow)
  approvedAt        DateTime?
  approvedByUserId  String?
  rejectionReason   String?       // Pflicht bei REJECTED

  createdAt         DateTime      @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([documentType])
  @@index([status])
  @@map("asset_documents")
}

// ═══════════════════════════════════════════════════════════════════════════════
// CLEARING & FINANCIAL SETTLEMENT — Doppelte Buchführung
//
// Konzept (Double-Entry Bookkeeping):
//   Jede Buchung = DEBIT (Soll) + CREDIT (Haben) mit gleicher correlationId
//   Invariante: SUM(DEBIT) == SUM(CREDIT) für jede correlationId
//
// Settlement-Ablauf nach CONTRACT_SIGNED:
//   1. Buyer zahlt Brutto   → DEBIT buyer_wallet   / CREDIT escrow
//   2. EUCX zieht Fee ab    → DEBIT escrow          / CREDIT eucx_revenue
//   3. MwSt. (falls fällig) → DEBIT escrow          / CREDIT vat_payable
//   4. Verkäufer erhält Net → DEBIT escrow          / CREDIT seller_wallet
//
// Sicherheit gegen Doppelbuchung:
//   LedgerEntry.idempotencyKey @unique — jeder Buchungssatz einmalig
//   Deal.status CHECK: nur CONTRACT_SIGNED darf gecleart werden
//   Gesamte Settlement-Runde in EINER DB-Transaktion
// ═══════════════════════════════════════════════════════════════════════════════

enum AccountType {
  TRADER_WALLET    // Händler-Wallet (Organisation)
  ESCROW           // Treuhandkonto während Transaktion
  EUCX_FEE_REVENUE // EUCX-Plattformgebühren-Einnahmen
  VAT_PAYABLE      // MwSt.-Verbindlichkeit (Finanzamt)
}

enum LedgerEntryType {
  DEBIT   // Soll  — Abgang / Belastung
  CREDIT  // Haben — Zugang / Gutschrift
}

enum InvoiceType {
  BUYER_INVOICE  // Kaufrechnung an Käufer (inkl. MwSt. oder Reverse Charge)
  SELLER_CREDIT  // Gutschrift an Verkäufer (Nettobetrag minus Fee)
  FEE_INVOICE    // EUCX-Plattformgebühr
}

enum InvoiceStatus {
  DRAFT      // Generiert, noch nicht versendet
  ISSUED     // Versendet
  PAID       // Bezahlt
  CANCELLED  // Storniert
}

enum SettlementStatus {
  REVERSED   // Storno: alle Buchungen wurden gegengebucht (Dispute TRADE_REVERSED)
  PENDING    // CONTRACT_SIGNED, warte auf Clearing
  PROCESSING // Clearing läuft gerade (BullMQ Job aktiv)
  COMPLETED  // Alle Buchungen abgeschlossen
  FAILED     // Fehler — manuelle Intervention nötig
}

model Wallet {
  id               String   @id @default(uuid())
  organizationId   String   @unique
  currency         Currency @default(EUR)
  // Gesamtguthaben (available + reserved)
  balance          Decimal  @db.Decimal(18, 8) @default(0)
  // Für laufende Gebote reservierter Betrag (nicht auszahlbar)
  reservedBalance  Decimal  @db.Decimal(18, 8) @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([organizationId])
  @@map("wallets")
}

model LedgerEntry {
  // ── Buchungsidentifikation ───────────────────────────────────────────────────
  id             String          @id @default(uuid())
  // Jeder Buchungssatz hat eine correlationId — DEBIT + CREDIT teilen sie sich
  // Invariante: für jede correlationId gilt sum(DEBIT) == sum(CREDIT)
  correlationId  String          // UUID des Buchungssatzes (STORNO-{id} für Gegenbuchungen)

  // ── Konto ───────────────────────────────────────────────────────────────────
  walletId       String?         // null für Systemkonten (EUCX_FEE_REVENUE, VAT_PAYABLE)
  accountType    AccountType

  // ── Buchungsart & Betrag ─────────────────────────────────────────────────────
  entryType      LedgerEntryType
  amount         Decimal         @db.Decimal(18, 8)  // immer positiv
  currency       Currency        @default(EUR)

  // ── Buchungstext (Pflicht — für Wirtschaftsprüfer) ───────────────────────────
  description    String

  // ── Referenzen ───────────────────────────────────────────────────────────────
  dealId         String?
  invoiceId      String?

  // ── Idempotenz-Schutz (verhindert Doppelbuchung bei Retry) ───────────────────
  // Format: "deal:{dealId}:step:{stepName}:{DEBIT|CREDIT}"
  idempotencyKey String          @unique

  createdAt      DateTime        @default(now())

  wallet Wallet? @relation(fields: [walletId], references: [id])

  @@index([correlationId])  // für Bilanzprüfung
  @@index([walletId])
  @@index([dealId])
  @@index([createdAt])
  @@map("ledger_entries")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique  // "EUCX-INV-2026-000001"
  type          InvoiceType
  status        InvoiceStatus @default(DRAFT)

  dealId        String
  issuerId      String        // Organization-ID (Aussteller)
  recipientId   String        // Organization-ID (Empfänger)

  // ── Beträge (alle in Decimal(18,8) — kein Float) ─────────────────────────────
  grossAmount   Decimal       @db.Decimal(18, 8)  // Brutto: pricePerUnit × quantity
  platformFee   Decimal       @db.Decimal(18, 8)  // EUCX-Gebühr (0.5% von gross)
  vatAmount     Decimal       @db.Decimal(18, 8)  // MwSt.-Betrag (0 bei Reverse Charge)
  vatRate       Decimal       @db.Decimal(5, 2)   // Satz: 19.00 | 0.00
  netPayable    Decimal       @db.Decimal(18, 8)  // Tatsächlich zu zahlen / zu erhalten
  currency      Currency      @default(EUR)

  // ── Steuer-Details ────────────────────────────────────────────────────────────
  isReverseCharge  Boolean    @default(false)  // EU B2B cross-border → Reverse Charge
  buyerTaxId       String?                     // USt-IdNr. des Käufers
  sellerTaxId      String?                     // USt-IdNr. des Verkäufers
  buyerCountry     String?    @db.Char(2)
  sellerCountry    String?    @db.Char(2)

  // ── Zeitstempel ───────────────────────────────────────────────────────────────
  issuedAt      DateTime?
  dueAt         DateTime?     // Zahlungsziel: issuedAt + 30 Tage
  paidAt        DateTime?

  // ── Dokument (PDF) ────────────────────────────────────────────────────────────
  pdfBase64     String?
  pdfHash       String?       // SHA-256 für Integrität

  createdAt     DateTime      @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([status])
  @@index([issuedAt])
  @@index([invoiceNumber])
  @@map("invoices")
}

model Settlement {
  id             String          @id @default(uuid())
  dealId         String          @unique  // 1:1 mit Deal
  status         SettlementStatus @default(PENDING)

  // ── Berechnete Werte (von ClearingService gesetzt) ────────────────────────────
  grossAmount    Decimal         @db.Decimal(18, 8)
  platformFee    Decimal         @db.Decimal(18, 8)
  vatAmount      Decimal         @db.Decimal(18, 8)
  netToSeller    Decimal         @db.Decimal(18, 8)
  currency       Currency        @default(EUR)

  // ── Verarbeitungs-Metadaten ───────────────────────────────────────────────────
  processedAt    DateTime?       // Wann abgeschlossen
  errorMessage   String?         // Bei FAILED: Fehlermeldung
  retryCount     Int             @default(0)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([status])
  @@map("settlements")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET DATA — OHLC-Kerzendaten für Charts
//
// Konzept:
//   MarketCandle = aggregierter Snapshot eines Zeitfensters (1m / 15m / 1h / 1d)
//   Wird NICHT aus Deals berechnet (zu langsam), sondern aus dem Cache gelesen.
//
//   Cache-Befüllung:
//     NestJS MarketDataService → @Cron() → runOhlcRefresh() → upsert()
//     PostgreSQL Raw-SQL OHLC-Query → MAX/MIN/FIRST/LAST über Deals-Tabelle
//
//   Idempotenz:
//     @@unique([productId, interval, periodStart]) → upsert ist idempotent
//
//   Index-Strategie:
//     @@index([productId, interval, periodStart]) → Chart-Query nutzt diesen vollständig
//     PostgreSQL kann einen einzigen Index-Scan machen (kein Sequential Scan)
// ═══════════════════════════════════════════════════════════════════════════════

enum CandleInterval {
  ONE_MIN       // 1 Minute
  FIFTEEN_MIN   // 15 Minuten
  ONE_HOUR      // 1 Stunde
  ONE_DAY       // 1 Tag
}

model MarketCandle {
  id          String         @id @default(uuid())
  productId   String
  interval    CandleInterval
  periodStart DateTime       // Beginn des Zeitfensters (truncated auf Intervall)

  // ── OHLC-Preise ────────────────────────────────────────────────────────────
  open        Decimal        @db.Decimal(18, 8)  // Erster Trade im Fenster
  high        Decimal        @db.Decimal(18, 8)  // Höchstpreis im Fenster
  low         Decimal        @db.Decimal(18, 8)  // Tiefstkurs im Fenster
  close       Decimal        @db.Decimal(18, 8)  // Letzter Trade im Fenster

  // ── Volumen ────────────────────────────────────────────────────────────────
  volume      Decimal        @db.Decimal(18, 8)  // Handelsmenge (Tonnen / MWh etc.)
  turnover    Decimal        @db.Decimal(24, 8)  // Handelsvolumen in EUR (qty × price)
  tradeCount  Int                                // Anzahl abgeschlossener Trades

  updatedAt   DateTime       @updatedAt

  product Product @relation(fields: [productId], references: [id])

  // Idempotenter Upsert: jede (product, interval, period) Kombination einmalig
  @@unique([productId, interval, periodStart])
  @@index([productId, interval, periodStart])   // Chart-Query: vollständiger Index-Scan
  @@index([productId, periodStart])             // für produktübergreifende Queries
  @@map("market_candles")
}

// ═══════════════════════════════════════════════════════════════════════════════
// API-ECONOMY — API-Keys & Webhooks für externe Partneranbindung
//
// API-Key Sicherheitsmodell:
//   Das secret wird NIE im Klartext gespeichert.
//   Format beim Erstellen: "eucx_live_{prefix}_{random32}"  (einmalig an User übergeben)
//   In DB:  prefix = "eucx_live_abc123"  + secretHash = bcrypt(full_secret)
//   Bei Anfrage: Header "X-EUCX-API-KEY: eucx_live_abc123_..." → prefix extrahieren
//               → ApiKey in DB suchen → bcrypt.compare(full, hash) → Scope-Check
//
// Webhook Sicherheitsmodell:
//   Jeder WebhookEndpoint hat ein eigenes HMAC-Signing-Secret.
//   Payload wird mit HMAC-SHA256 signiert: X-EUCX-Signature: sha256={hex}
//   Empfänger prüft: HMAC(payload, secret) == signature → authentisch
//   Retry via BullMQ: 5min → 15min → 60min (exponentiell)
// ═══════════════════════════════════════════════════════════════════════════════

enum WebhookEvent {
  TRADE_MATCHED          // Deal erstellt (Matching)
  TRADE_SETTLEMENT_COMPLETE  // Clearing abgeschlossen
  TRADE_CANCELLED        // Trade storniert
  TRADE_DISPUTED         // Dispute eröffnet
  CONTRACT_SIGNED        // Vertrag unterzeichnet
  ORDER_PLACED           // Order eingegangen
  ORDER_CANCELLED        // Order storniert
  PRICE_ALERT            // Preis-Schwelle überschritten (zukünftig)
}

enum WebhookDeliveryStatus {
  PENDING   // Noch nicht gesendet (in Queue)
  SUCCESS   // HTTP 2xx erhalten
  FAILED    // Alle Versuche erschöpft
  RETRYING  // Nächster Versuch ausstehend
}

model ApiKey {
  id             String   @id @default(uuid())
  organizationId String
  createdByUserId String

  // ── Schlüsselidentifikation ───────────────────────────────────────────────
  // prefix: öffentlich sichtbar für Identifikation (z.B. in Logs)
  // secretHash: bcrypt(full_key) — NIEMALS Klartext speichern
  prefix         String   @unique   // z.B. "eucx_live_k7mNpQ"
  secretHash     String             // bcrypt-Hash des vollständigen Keys

  // ── Berechtigungen ────────────────────────────────────────────────────────
  // Scopes: ["market:read", "trade:write", "wallet:read", "admin:read"]
  scopes         String[]

  // ── Metadaten ─────────────────────────────────────────────────────────────
  name           String             // Beschreibungstext (z.B. "ERP-System SAP")
  isActive       Boolean  @default(true)
  expiresAt      DateTime?          // null = kein Ablaufdatum
  lastUsedAt     DateTime?
  ipWhitelist    String[]           // optional: nur von diesen IPs

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([prefix])              // Schnelle Suche beim Auth-Check
  @@index([organizationId])
  @@map("api_keys")
}

model WebhookEndpoint {
  id             String         @id @default(uuid())
  organizationId String

  url            String         // Ziel-URL des Partners
  events         WebhookEvent[] // welche Events triggern diesen Webhook
  signingSecret  String         // HMAC-Signing-Secret (32 Bytes Hex, Klartext ok — bleibt server-seitig)
  isActive       Boolean        @default(true)
  description    String?        // z.B. "SAP-ERP Produktionsserver"

  // Statistiken
  successCount   Int            @default(0)
  failureCount   Int            @default(0)
  lastTriggeredAt DateTime?
  lastStatusCode  Int?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  deliveries   WebhookDelivery[]

  @@index([organizationId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String                @id @default(uuid())
  endpointId  String
  event       WebhookEvent
  payload     Json                  // Gesendeter Payload (für Re-Delivery)
  status      WebhookDeliveryStatus @default(PENDING)

  // Versuchs-Protokoll
  attemptCount  Int      @default(0)
  nextRetryAt   DateTime?
  lastStatusCode Int?
  lastError     String?
  responseBody  String?   @db.Text  // Antwort des Partner-Servers (für Debugging)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId, status])
  @@index([status, nextRetryAt])  // Retry-Queue: alle RETRYING mit nextRetryAt <= now()
  @@map("webhook_deliveries")
}

// ═══════════════════════════════════════════════════════════════════════════════
// REVERSE AUCTION (BUTB — Buyer-Takes-Best)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Lot — Ausschreibung des Käufers ─────────────────────────────────────────
// Der Käufer definiert Ware + Maximalpreis. Verkäufer bieten dann nach unten.
// Phase-Übergänge sind unidirektional und servergesichert (kein Client-Trigger).
//
// State Machine:
//   COLLECTION  → Lot erstellt, Verkäufer können sich registrieren
//   PROPOSAL    → Käufer öffnet Auktion (auctionStart gesetzt), Erstgebote möglich
//   REDUCTION   → Nur noch Gebote < currentBest erlaubt (PriceEngine prüft)
//   CONCLUSION  → lockedAt gesetzt, winnerId fixiert, keine Änderungen mehr möglich
model Lot {
  id           String       @id @default(cuid())
  buyerId      String
  commodity    String       // z.B. "Betonstahl BST 500", "Kupferkathode Grade A"
  quantity     Decimal      @db.Decimal(18, 4)
  unit         CommodityUnit
  phase        AuctionPhase @default(COLLECTION)
  description  String?      @db.Text   // Käufer-Ausschreibungstext
  startPrice   Decimal?     @db.Decimal(18, 2)  // Käufer-Maximalpreis (€/Einheit)
  currentBest  Decimal?     @db.Decimal(18, 2)  // Aktuell niedrigstes Gebot
  winnerId     String?
  auctionStart DateTime?    // Wann PROPOSAL begann
  auctionEnd   DateTime?    // Fester Schlusszeitpunkt (auctionStart + 2h)
  lockedAt     DateTime?    // Zeitpunkt CONCLUSION (danach unveränderlich)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  buyer         User              @relation("LotBuyer",  fields: [buyerId],   references: [id])
  winner        User?             @relation("LotWinner", fields: [winnerId],   references: [id])
  bids          Bid[]
  registrations LotRegistration[]
  lotContract   LotContract?

  @@index([buyerId])
  @@index([phase])               // Offene Auktionen schnell abrufen
  @@index([auctionEnd, phase])   // AuctionTimer: fällige Übergänge finden
  @@map("lots")
}

// ─── LotRegistration — Verkäufer-Anmeldung zur Auktion ───────────────────────
// Nur registrierte Verkäufer können in PROPOSAL/REDUCTION Gebote abgeben.
// Registrierung nur in Phase COLLECTION möglich.
model LotRegistration {
  id        String   @id @default(cuid())
  lotId     String
  sellerId  String
  createdAt DateTime @default(now())

  lot    Lot  @relation(fields: [lotId],    references: [id], onDelete: Cascade)
  seller User @relation(fields: [sellerId], references: [id])

  @@unique([lotId, sellerId])   // Jeder Verkäufer nur einmal pro Lot
  @@index([sellerId])
  @@map("lot_registrations")
}

// ─── Bid — Gebot eines Verkäufers ────────────────────────────────────────────
// Jedes Gebot ist unveränderlich (append-only). Die History bleibt vollständig.
// PriceEngine stellt sicher: price < Lot.currentBest (Row-Lock auf Lot).
// isWinner wird nur bei CONCLUSION gesetzt, exakt einmal pro Lot.
model Bid {
  id        String   @id @default(cuid())
  lotId     String
  sellerId  String
  price     Decimal  @db.Decimal(18, 2)  // €/Einheit
  isWinner  Boolean  @default(false)
  createdAt DateTime @default(now())

  lot    Lot  @relation(fields: [lotId],    references: [id], onDelete: Cascade)
  seller User @relation(fields: [sellerId], references: [id])

  @@index([lotId, price])       // Bestes Gebot schnell ermitteln
  @@index([lotId, sellerId])    // Gebote eines Verkäufers für ein Lot
  @@map("bids")
}

// ─── LotContract — Kaufvertrag nach Abschluss der Auktion ────────────────────
// Wird automatisch bei CONCLUSION generiert (Post-Trade Engine).
// PDF = pdf-lib generiertes A4-Dokument (gov-blue EUCX-Layout).
// pdfHash = SHA-256 für Fälschungssicherheit.
//
// contractNumber Format: "EUCX-LOT-2026-000001" (sequentiell)
//
// LotFee: Plattformgebühr pro Partei
//   Verkäufer: 0.8% Standard / 0.5% High-Volume (> 500.000 € Gesamtumsatz)
//   Käufer:    0.3% Standard / 0.15% High-Volume
//   Status UNPAID → PAID nach Wallet-Abbuchung

enum LotFeeType {
  SELLER_FEE
  BUYER_FEE
}

enum LotFeeStatus {
  UNPAID
  PAID
}

model LotContract {
  id             String    @id @default(cuid())
  lotId          String    @unique
  buyerId        String
  sellerId       String
  contractNumber String    @unique
  finalPrice     Decimal   @db.Decimal(18, 2)   // €/Einheit — Siegergebot
  totalValue     Decimal   @db.Decimal(18, 2)   // finalPrice × lot.quantity
  pdfBase64      String    @db.Text
  pdfHash        String
  pdfSizeBytes   Int
  signedAtBuyer  DateTime?
  signedAtSeller DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lot    Lot  @relation(fields: [lotId],    references: [id])
  buyer  User @relation("LotContractBuyer",  fields: [buyerId],  references: [id])
  seller User @relation("LotContractSeller", fields: [sellerId], references: [id])
  fees   LotFee[]

  @@index([buyerId])
  @@index([sellerId])
  @@map("lot_contracts")
}

model LotFee {
  id         String       @id @default(cuid())
  contractId String
  userId     String
  type       LotFeeType
  rate       Decimal      @db.Decimal(5, 4)   // z.B. 0.0080 = 0.8%
  amount     Decimal      @db.Decimal(18, 2)
  status     LotFeeStatus @default(UNPAID)
  createdAt  DateTime     @default(now())

  contract LotContract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@index([userId])
  @@map("lot_fees")
}

// ─── KycDocument — hochgeladene Verifizierungsdokumente ──────────────────────
// Jeder User kann mehrere Dokumente hochladen (Handelsregisterauszug, USt-IdNr.).
// Admin (COMPLIANCE_OFFICER) prüft und ändert status → APPROVED/REJECTED.
// Wenn alle Dokumente APPROVED: verificationStatus → VERIFIED (via Admin-API).
model KycDocument {
  id         String       @id @default(cuid())
  userId     String
  name       String                    // Original-Dateiname
  url        String?                   // Storage-URL (S3, Supabase Storage, etc.)
  type       String                    // "TRADE_REGISTER" | "VAT_CONFIRMATION" | "ID_DOCUMENT" | "OTHER"
  sizeMb     Float
  notes      String?      @db.Text    // Optionale Notiz des Users
  adminNote  String?      @db.Text    // Ablehnungsgrund (vom Admin)
  status     KycDocStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])   // Admin-Queue: alle PENDING schnell abrufen
  @@map("kyc_documents")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTIFICATION ENGINE — Realtime-Benachrichtigungen (In-App + E-Mail)
//
// Ablauf:
//   1. Event tritt auf (Gebot überboten, Auktion endet bald, Sieger fixiert)
//   2. NotificationService erstellt Notification-Datensatz in DB
//   3. SSE-Stream liefert `event: notification` Payload an verbundene Clients
//   4. Frontend: Toast (sonner) + Vibration (navigator.vibrate) + Bell-Badge
//   5. E-Mail (Resend) wird asynchron versendet wenn Präferenz aktiv
//
// NotifType-Semantik:
//   OUTBID         → Verkäufer wurde von einem anderen überboten (Rang 1 verloren)
//   LEADING        → Verkäufer ist jetzt das führende Gebot (Rang 1 gewonnen)
//   URGENCY_10M    → 10 Minuten vor Auktionsende (alle registrierten Teilnehmer)
//   URGENCY_5M     → 5 Minuten vor Auktionsende (alle registrierten Teilnehmer)
//   WON            → Sieger nach CONCLUSION
//   LOST           → Auktion vorbei, kein Sieger (Verkäufer)
//   CLOSED_BUYER   → Auktion abgeschlossen (Käufer)
//   DEPOSIT_WARN   → Wallet-Saldo gefährlich nahe an 5%-Schwelle
// ═══════════════════════════════════════════════════════════════════════════════

enum NotifType {
  OUTBID
  LEADING
  URGENCY_10M
  URGENCY_5M
  WON
  LOST
  CLOSED_BUYER
  DEPOSIT_WARN
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  lotId     String?                    // Zugeordnetes Lot (null für systemweite Alerts)
  type      NotifType
  title     String
  message   String
  isRead    Boolean   @default(false)  // true nach Klick im Bell-Dropdown
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([lotId])
  @@map("notifications")
}

// ─── NotificationPreference — Nutzer-Präferenzen für E-Mail-Benachrichtigungen
// Wird beim ersten GET/PATCH angelegt falls noch nicht vorhanden (upsert).
model NotificationPreference {
  id                  String  @id @default(cuid())
  userId              String  @unique
  emailOnOutbid       Boolean @default(true)
  emailOnAuctionEnd   Boolean @default(true)
  emailOnAuctionStart Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
