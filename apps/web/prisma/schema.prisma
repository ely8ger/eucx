generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Nutzer & Organisationen ──────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SELLER
  BUYER
  BROKER
  OBSERVER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// ─── Warengruppen (wie BUTB) ──────────────────────────────────────────────────

enum CommodityCategory {
  METALS           // Metalle & Legierungen
  SCRAP            // Schrott & Sekundärrohstoffe
  TIMBER           // Holz & Forstprodukte
  AGRICULTURE      // Agrarprodukte & Lebensmittel
  CHEMICALS        // Chemikalien & Petrochemie
  ENERGY           // Energie (Koks, Kohle, Pellets)
  CONSTRUCTION     // Baustoffe
  INDUSTRIALS      // Industriegüter & Maschinen
}

enum CommodityUnit {
  TON              // Tonne
  KG               // Kilogramm
  CBM              // Kubikmeter (Holz)
  LITER            // Liter
  PIECE            // Stück
  SQM              // Quadratmeter
}

// ─── Order & Deal ─────────────────────────────────────────────────────────────

enum OrderDirection {
  BUY
  SELL
}

enum OrderStatus {
  ACTIVE
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
}

enum SessionStatus {
  SCHEDULED
  PRE_TRADING
  TRADING_1
  CORRECTION_1
  TRADING_2
  CORRECTION_2
  FINAL
  CLOSED
}

enum DealStatus {
  MATCHED
  CONFIRMED
  CANCELLED
  DISPUTED
}

enum Currency {
  EUR
  PLN
  USD
  GBP
  CZK
}

// ─── Modelle ──────────────────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(uuid())
  name       String
  taxId      String   @unique
  country    String   @db.Char(2)
  city       String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  users         User[]
  products      Product[]
  orders        Order[]
  dealsAsSeller Deal[]    @relation("SellerOrg")
  dealsAsBuyer  Deal[]    @relation("BuyerOrg")

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  organizationId String
  email          String     @unique
  passwordHash   String
  role           UserRole   @default(BUYER)
  status         UserStatus @default(PENDING)
  totpSecret     String?
  totpEnabled    Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  orders        Order[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([organizationId])
  @@map("users")
}

// ─── Produkt (universell für alle Warengruppen) ───────────────────────────────

model Product {
  id                String            @id @default(uuid())
  organizationId    String
  category          CommodityCategory
  subcategory       String            // z.B. "Rebar", "Round Wood", "Milk Powder"
  name              String            // Handelsname
  description       String?
  unit              CommodityUnit     @default(TON)
  quantity          Decimal           @db.Decimal(12, 3)
  minLotQuantity    Decimal           @default(1.0) @db.Decimal(12, 3)
  originCountry     String            @db.Char(2)
  warehouseLocation String
  hasCertificate    Boolean           @default(false)
  certificateNumber String?
  specifications    Json?             // Kategorie-spezifische Felder (JSONB)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id])
  tradingSessions TradingSession[]
  orders          Order[]
  deals           Deal[]

  @@index([organizationId])
  @@index([category])
  @@map("products")
}

model TradingSession {
  id             String        @id @default(uuid())
  productId      String
  currentStatus  SessionStatus @default(SCHEDULED)
  scheduledStart DateTime
  endedAt        DateTime?
  createdAt      DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id])
  orders  Order[]
  deals   Deal[]

  @@index([productId])
  @@index([currentStatus])
  @@map("trading_sessions")
}

model Order {
  id             String         @id @default(uuid())
  sessionId      String
  userId         String
  organizationId String
  productId      String
  direction      OrderDirection
  pricePerUnit   Decimal        @db.Decimal(12, 2)
  currency       Currency       @default(EUR)
  quantity       Decimal        @db.Decimal(12, 3)
  filledQuantity Decimal        @default(0) @db.Decimal(12, 3)
  status         OrderStatus    @default(ACTIVE)
  idempotencyKey String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  session      TradingSession @relation(fields: [sessionId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  organization Organization   @relation(fields: [organizationId], references: [id])
  product      Product        @relation(fields: [productId], references: [id])
  dealsAsSell  Deal[]         @relation("SellOrder")
  dealsAsBuy   Deal[]         @relation("BuyOrder")

  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([direction, pricePerUnit])
  @@map("orders")
}

model Deal {
  id             String     @id @default(uuid())
  sessionId      String
  sellOrderId    String
  buyOrderId     String
  sellerOrgId    String
  buyerOrgId     String
  productId      String
  quantity       Decimal    @db.Decimal(12, 3)
  pricePerUnit   Decimal    @db.Decimal(12, 2)
  currency       Currency   @default(EUR)
  status         DealStatus @default(MATCHED)
  buyerSignature String?
  createdAt      DateTime   @default(now())

  session   TradingSession @relation(fields: [sessionId], references: [id])
  sellOrder Order          @relation("SellOrder", fields: [sellOrderId], references: [id])
  buyOrder  Order          @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellerOrg Organization   @relation("SellerOrg", fields: [sellerOrgId], references: [id])
  buyerOrg  Organization   @relation("BuyerOrg", fields: [buyerOrgId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])

  @@index([sessionId])
  @@index([sellerOrgId])
  @@index([buyerOrgId])
  @@map("deals")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // z.B. "AUTH_LOGIN", "ORDER_SUBMITTED", "PRODUCT_UPDATED"
  entityType String   // z.B. "Order", "Product", "User"
  entityId   String?
  ipAddress  String?
  userAgent  String?
  meta       Json?    // Freie Metadaten (JSONB) — unveränderlich nach Insert
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

// ─── Double-Spending-Schutz: Product Lock ─────────────────────────────────────
//
// Problem: Verkäufer A hat 100t Stahl. Order X belegt 100t. Bevor Order X
// abgeschlossen ist, stellt Verkäufer A Order Y für dieselben 100t auf.
//
// Lösung auf DB-Ebene:
// 1. filledQuantity in Order: Cursor über tatsächlich reservierte Menge
// 2. CHECK-Constraint (via Migration): filledQuantity <= quantity
// 3. Beim Matching: SELECT FOR UPDATE auf die Order-Zeile (Row-Level Lock)
//    → zwei parallele Transaktionen können nicht dieselbe Order gleichzeitig füllen
// 4. idempotencyKey UNIQUE: verhindert doppelte Submission derselben Order
