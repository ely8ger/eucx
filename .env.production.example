# ─── EUCX Production Environment Variables ────────────────────────────────────
# Copy to .env.production on the server, NEVER commit this file.
# All values marked CHANGE_ME must be set before deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL / Neon) ──────────────────────────────────────────────
# For self-hosted Docker: postgresql://eucx:pass@postgres:5432/eucx
# For Neon: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/eucx?sslmode=require
POSTGRES_DB=eucx
POSTGRES_USER=eucx
POSTGRES_PASSWORD=CHANGE_ME_strong_password_32chars

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public&connection_limit=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_32_char_secret_here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── NextAuth (Next.js web) ────────────────────────────────────────────────────
NEXTAUTH_URL=https://eucx.exchange
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_32chars

# ── Public URLs ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.eucx.exchange
NEXT_PUBLIC_WS_URL=wss://api.eucx.exchange
NEXT_PUBLIC_BASE_URL=https://eucx.exchange
NEXT_PUBLIC_APP_URL=https://eucx.exchange

# ── NestJS Internal (Next.js → NestJS service-to-service) ────────────────────
NESTJS_INTERNAL_URL=http://api:3001

# ── Neon DB (wenn Neon statt self-hosted PostgreSQL) ─────────────────────────
# DIRECT_URL wird für Prisma-Migrationen benötigt (kein Pooling)
# DIRECT_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/eucx?sslmode=require

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@eucx.exchange
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM=noreply@eucx.exchange

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Global signing secret for HMAC-SHA256 webhook signatures
WEBHOOK_SECRET=CHANGE_ME_webhook_signing_secret_64chars

# ── Internal Service Auth ─────────────────────────────────────────────────────
# Used for service-to-service calls (NestJS → Next.js internal routes)
INTERNAL_API_KEY=CHANGE_ME_internal_api_key

# ── Docker / GHCR ─────────────────────────────────────────────────────────────
GITHUB_REPO_OWNER=your-github-username-or-org
API_IMAGE_TAG=latest
WEB_IMAGE_TAG=latest

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password

# ── Deployment SSH (used by GitHub Actions — stored as GitHub Secrets) ────────
# DEPLOY_HOST=your.server.ip.address
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY=(private key — store in GitHub Actions secret)
# DEPLOY_PORT=22

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_KYC_REQUIRED=true
ENABLE_WEBHOOK_DELIVERY=true
ENABLE_MARKET_CANDLE_CACHE=true
MAX_API_KEYS_PER_ORG=10

# ── Backup (S3-kompatibel: AWS S3, MinIO, Cloudflare R2) ─────────────────────
BACKUP_S3_BUCKET=eucx-backups-prod
BACKUP_S3_PREFIX=eucx/backups
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=eu-central-1

# ── Seed (nur einmalig für Production Seed benötigt) ─────────────────────────
SEED_ADMIN_EMAIL=admin@eucx.eu
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_2026

# ── Rate Limits (override defaults) ──────────────────────────────────────────
ORDER_RATE_LIMIT_PER_MIN=30
API_RATE_LIMIT_PER_MIN=100
AUTH_RATE_LIMIT_PER_MIN=10

# ── SSL / Certbot ─────────────────────────────────────────────────────────────
# Domains for Let's Encrypt certificate:
# certbot certonly --webroot -w /var/www/certbot \
#   -d eucx.exchange -d api.eucx.exchange -d grafana.eucx.exchange \
#   --email admin@eucx.exchange --agree-tos --non-interactive
CERTBOT_EMAIL=admin@eucx.exchange
CERTBOT_DOMAINS=eucx.exchange,api.eucx.exchange,grafana.eucx.exchange
