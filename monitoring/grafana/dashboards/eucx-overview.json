{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "EUCX Platform Overview — API latency, order throughput, DB connections, Redis memory",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"eucx_api\"}[5m])) by (le, route))",
          "legendFormat": "p95 {{ route }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"eucx_api\"}[5m])) by (le))",
          "legendFormat": "p99 all",
          "refId": "B"
        }
      ],
      "title": "API Latency (p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"eucx_api\"}[1m])) by (status_code)",
          "legendFormat": "HTTP {{ status_code }}",
          "refId": "A"
        }
      ],
      "title": "API Request Rate by Status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Trading Engine",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "increase(eucx_orders_total{job=\"eucx_api\"}[1m])",
          "legendFormat": "Orders / min",
          "refId": "A"
        },
        {
          "expr": "increase(eucx_deals_total{job=\"eucx_api\"}[1m])",
          "legendFormat": "Deals / min",
          "refId": "B"
        }
      ],
      "title": "Order & Deal Throughput",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "currencyEUR", "color": { "mode": "thresholds" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "eucx_tvl_eur{job=\"eucx_api\"}",
          "legendFormat": "TVL (EUR)",
          "refId": "A"
        }
      ],
      "title": "Total Value Locked (TVL)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "eucx_bullmq_queue_size{job=\"eucx_api\", queue=\"MATCHING\"}",
          "legendFormat": "MATCHING queue",
          "refId": "A"
        },
        {
          "expr": "eucx_bullmq_queue_size{job=\"eucx_api\", queue=\"WEBHOOK_DELIVERY\"}",
          "legendFormat": "WEBHOOK queue",
          "refId": "B"
        }
      ],
      "title": "BullMQ Queue Depth",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Infrastructure",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\", state=\"active\"}",
          "legendFormat": "Active connections",
          "refId": "A"
        },
        {
          "expr": "pg_settings_max_connections{job=\"postgres\"}",
          "legendFormat": "Max connections",
          "refId": "B"
        }
      ],
      "title": "PostgreSQL Connections",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max (512MB)",
          "refId": "B"
        }
      ],
      "title": "Redis Memory",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU {{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Host CPU Usage",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["eucx", "production"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Berlin",
  "title": "EUCX Platform Overview",
  "uid": "eucx-overview-v1",
  "version": 1
}
