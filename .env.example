# ─── EUCX Environment Variables ───────────────────────────────────────────────
# Kopiere diese Datei als:
#   .env.local          → lokale Entwicklung
#   Vercel Dashboard    → Frontend (eucx.eu)
#   /opt/eucx/.env.production → Server (api.eucx.eu + Docker)
#
# NIEMALS echte Passwörter in diese Datei eintragen und commiten!
# ─────────────────────────────────────────────────────────────────────────────

# ── Datenbank (Neon PostgreSQL / Docker PostgreSQL) ───────────────────────────
# Neon (Production):  postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/eucx?sslmode=require
# Docker (lokal):     postgresql://eucx:eucx_secret@localhost:5432/eucx
DATABASE_URL=postgresql://USER:PASS@HOST/eucx?sslmode=require
DIRECT_URL=postgresql://USER:PASS@HOST/eucx?sslmode=require

# Nur für Docker self-hosted:
POSTGRES_DB=eucx
POSTGRES_USER=eucx
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Mindestens 32 zufällige Zeichen — z.B.: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_chars

# ── URLs ──────────────────────────────────────────────────────────────────────
# Lokal:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
# Production (Vercel):
# NEXT_PUBLIC_BASE_URL=https://eucx.eu
# NEXT_PUBLIC_API_URL=https://api.eucx.eu
# NEXT_PUBLIC_WS_URL=wss://api.eucx.eu

# ── NestJS API intern (Next.js → NestJS service-to-service) ──────────────────
NESTJS_INTERNAL_URL=http://localhost:3001
INTERNAL_API_KEY=CHANGE_ME

# ── E-Mail (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@eucx.eu
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@eucx.eu

# ── Webhooks ──────────────────────────────────────────────────────────────────
# HMAC-SHA256 Signing Secret — min. 64 zufällige Zeichen
WEBHOOK_SECRET=CHANGE_ME

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_KYC_REQUIRED=true
ENABLE_WEBHOOK_DELIVERY=true
MAX_API_KEYS_PER_ORG=10

# ── Vercel (nur für CLI-Deploy) ───────────────────────────────────────────────
# vercel whoami → Org- und Projekt-ID im Dashboard unter Settings
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Backup / S3 (optional, für Production-Backups) ───────────────────────────
BACKUP_S3_BUCKET=eucx-backups-prod
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=eu-central-1

# ── Monitoring (nur Docker/Server) ───────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

# ── Initialer Admin-Account (nur einmalig für Seed) ──────────────────────────
SEED_ADMIN_EMAIL=admin@eucx.eu
SEED_ADMIN_PASSWORD=CHANGE_ME
