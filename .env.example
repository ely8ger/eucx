# ─── Datenbank ────────────────────────────────────────────────────────────────
POSTGRES_DB=eucx_dev
POSTGRES_USER=eucx
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── JWT (RSA 4096-bit Schlüsselpaar) ─────────────────────────────────────────
# Generieren mit:
#   openssl genrsa -out infra/certs/jwt_private.pem 4096
#   openssl rsa -in infra/certs/jwt_private.pem -pubout -out infra/certs/jwt_public.pem
JWT_PRIVATE_KEY_PATH=./infra/certs/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./infra/certs/jwt_public.pem
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000,https://eucx.eu

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_DOMAIN=eucx.eu

# ─── E-Mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@eucx.eu
SMTP_PASSWORD=CHANGE_ME

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME
