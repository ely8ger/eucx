# ─── Datenbank ────────────────────────────────────────────────────────────────
POSTGRES_DB=eucx_dev
POSTGRES_USER=eucx
POSTGRES_PASSWORD=eucx_secret

# Neon PostgreSQL (Production)
DATABASE_URL=postgresql://USER:PASS@HOST/eucx?sslmode=require
DIRECT_URL=postgresql://USER:PASS@HOST/eucx?sslmode=require

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=min-32-zeichen-geheimes-passwort-hier

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── Vercel ───────────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
